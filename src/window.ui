<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>

  <menu id="primary_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">Add Photo Folder…</attribute>
        <attribute name="action">win.add-folder</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">New Album…</attribute>
        <attribute name="action">win.new-album</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Rescan Library</attribute>
        <attribute name="action">win.rescan</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">Preferences</attribute>
        <attribute name="action">win.preferences</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Keyboard Shortcuts</attribute>
        <attribute name="action">win.show-help-overlay</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">About Easel</attribute>
        <attribute name="action">app.about</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Quit</attribute>
        <attribute name="action">app.quit</attribute>
      </item>
    </section>
  </menu>

  <template class="EaselWindow" parent="AdwApplicationWindow">
    <property name="default-width">1180</property>
    <property name="default-height">740</property>
    <property name="width-request">720</property>
    <property name="height-request">520</property>
    <property name="title">Easel</property>
    <property name="content">
      <object class="AdwToastOverlay" id="toast_overlay">
        <property name="child">
      <object class="GtkOverlay" id="root_overlay">
        <property name="child">
      <object class="GtkBox" id="root_box">
        <property name="orientation">vertical</property>
        <style>
          <class name="root-bg"/>
        </style>

        <!-- Row 1 — thin titlebar / drag handle. The thumbnail-size + menu group
             sits opposite the window controls (_apply_titlebar_side). -->
        <child>
          <object class="GtkWindowHandle" id="titlebar_handle">
            <property name="height-request">48</property>
            <property name="child">
              <object class="GtkBox" id="titlebar_box">
                <property name="orientation">horizontal</property>
                <property name="spacing">6</property>
                <property name="margin-start">16</property>
                <property name="margin-end">8</property>
                <property name="valign">center</property>
                <child>
                  <object class="GtkWindowControls" id="wc_start">
                    <property name="side">start</property>
                    <property name="valign">center</property>
                  </object>
                </child>
                <child>
                  <object class="GtkScale" id="thumb_scale">
                    <property name="orientation">horizontal</property>
                    <property name="draw-value">false</property>
                    <property name="width-request">120</property>
                    <property name="valign">center</property>
                    <property name="tooltip-text" translatable="yes">Thumbnail size</property>
                    <property name="adjustment">
                      <object class="GtkAdjustment">
                        <property name="lower">110</property>
                        <property name="upper">320</property>
                        <property name="value">168</property>
                        <property name="step-increment">8</property>
                      </object>
                    </property>
                    <style>
                      <class name="thumb-scale"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkMenuButton" id="menu_button">
                    <property name="icon-name">open-menu-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Main Menu</property>
                    <property name="valign">center</property>
                    <property name="menu-model">primary_menu</property>
                    <style>
                      <class name="flat"/>
                      <class name="circular"/>
                      <class name="titlebar-icon"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="titlebar_spacer">
                    <property name="hexpand">true</property>
                  </object>
                </child>
                <child>
                  <object class="GtkWindowControls" id="wc_end">
                    <property name="side">end</property>
                    <property name="valign">center</property>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>

        <!-- Row 2 — navigation band: the two tab groups (left) / search entry,
             with sort + search on the right. -->
        <child>
          <object class="GtkBox" id="nav_row">
            <property name="orientation">horizontal</property>
            <property name="spacing">8</property>
            <property name="margin-top">24</property>
            <property name="margin-bottom">18</property>
            <property name="valign">center</property>
            <child>
              <object class="GtkStack" id="middle_stack">
                <property name="hexpand">true</property>
                <property name="valign">center</property>
                <property name="transition-type">crossfade</property>
                <property name="transition-duration">100</property>
                <child>
                  <object class="GtkStackPage">
                    <property name="name">view</property>
                    <property name="child">
                      <object class="GtkBox" id="tabs_box">
                        <property name="orientation">horizontal</property>
                        <property name="spacing">12</property>
                        <property name="halign">start</property>
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <style>
                              <class name="tab-group"/>
                            </style>
                            <child>
                              <object class="GtkButton" id="tab_all_photos">
                                <property name="label" translatable="yes">All Photos</property>
                                <style>
                                  <class name="flat"/>
                                  <class name="tab-btn"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="tab_months">
                                <property name="label" translatable="yes">Months</property>
                                <style>
                                  <class name="flat"/>
                                  <class name="tab-btn"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="tab_years">
                                <property name="label" translatable="yes">Years</property>
                                <style>
                                  <class name="flat"/>
                                  <class name="tab-btn"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <style>
                              <class name="tab-group"/>
                            </style>
                            <child>
                              <object class="GtkButton" id="tab_albums">
                                <property name="label" translatable="yes">Albums</property>
                                <style>
                                  <class name="flat"/>
                                  <class name="tab-btn"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="tab_favourites">
                                <property name="label" translatable="yes">Favourites</property>
                                <style>
                                  <class name="flat"/>
                                  <class name="tab-btn"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="tab_maps">
                                <property name="label" translatable="yes">Maps</property>
                                <style>
                                  <class name="flat"/>
                                  <class name="tab-btn"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="tab_people">
                                <property name="label" translatable="yes">People</property>
                                <style>
                                  <class name="flat"/>
                                  <class name="tab-btn"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="GtkStackPage">
                    <property name="name">search</property>
                    <property name="child">
                      <object class="GtkSearchEntry" id="search_entry">
                        <property name="placeholder-text" translatable="yes">Search</property>
                        <property name="hexpand">true</property>
                        <property name="valign">center</property>
                        <style>
                          <class name="search-entry"/>
                        </style>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkMenuButton" id="sort_btn">
                <property name="icon-name">easel-sort-symbolic</property>
                <property name="tooltip-text" translatable="yes">Sort</property>
                <property name="valign">center</property>
                <style>
                  <class name="flat"/>
                  <class name="circular"/>
                  <class name="titlebar-icon"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkToggleButton" id="search_toggle_btn">
                <property name="tooltip-text" translatable="yes">Search</property>
                <property name="valign">center</property>
                <style>
                  <class name="flat"/>
                  <class name="circular"/>
                  <class name="titlebar-icon"/>
                </style>
                <child>
                  <object class="GtkImage">
                    <property name="icon-name">system-search-symbolic</property>
                    <property name="pixel-size">14</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- Content: the paper library card and the slide-in info panel -->
        <child>
          <object class="GtkBox" id="content_row">
            <property name="orientation">horizontal</property>
            <property name="hexpand">true</property>
            <property name="vexpand">true</property>

            <child>
              <object class="GtkBox" id="paper">
                <property name="orientation">vertical</property>
                <property name="hexpand">true</property>
                <property name="vexpand">true</property>
                <style>
                  <class name="paper"/>
                </style>

                <child>
                  <object class="GtkCenterBox" id="detail_back_row">
                    <property name="visible">false</property>
                    <property name="margin-top">24</property>
                    <property name="margin-start">32</property>
                    <property name="margin-end">32</property>
                    <property name="start-widget">
                      <object class="GtkButton" id="back_btn">
                        <style>
                          <class name="back-btn"/>
                        </style>
                        <child>
                          <object class="AdwButtonContent">
                            <property name="icon-name">go-previous-symbolic</property>
                            <property name="label" translatable="yes">Back</property>
                          </object>
                        </child>
                      </object>
                    </property>
                    <property name="end-widget">
                      <object class="GtkLabel" id="detail_kind_label">
                        <property name="label" translatable="yes">Album</property>
                        <style>
                          <class name="eyebrow"/>
                        </style>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="GtkStack" id="paper_stack">
                    <property name="vexpand">true</property>
                    <property name="hexpand">true</property>
                    <property name="transition-type">crossfade</property>
                    <property name="transition-duration">120</property>

                    <child>
                      <object class="GtkStackPage">
                        <property name="name">empty</property>
                        <property name="child">
                          <object class="AdwStatusPage">
                            <property name="icon-name">image-x-generic-symbolic</property>
                            <property name="title" translatable="yes">No Photos Yet</property>
                            <property name="description" translatable="yes">Add a folder and Easel will scan it for photos.</property>
                            <property name="child">
                              <object class="GtkButton">
                                <property name="label" translatable="yes">Add Photo Folder…</property>
                                <property name="halign">center</property>
                                <property name="action-name">win.add-folder</property>
                                <style>
                                  <class name="pill"/>
                                  <class name="empty-cta"/>
                                </style>
                              </object>
                            </property>
                          </object>
                        </property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkStackPage">
                        <property name="name">all_photos</property>
                        <property name="child">
                          <object class="GtkScrolledWindow">
                            <property name="hscrollbar-policy">never</property>
                            <style>
                              <class name="om-scroll"/>
                            </style>
                            <property name="child">
                              <object class="GtkGridView" id="photo_grid">
                                <property name="min-columns">2</property>
                                <property name="max-columns">12</property>
                                <property name="margin-top">24</property>
                                <property name="margin-bottom">1</property>
                                <property name="margin-start">32</property>
                                <property name="margin-end">32</property>
                                <style>
                                  <class name="card-grid"/>
                                </style>
                              </object>
                            </property>
                          </object>
                        </property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkStackPage">
                        <property name="name">months</property>
                        <property name="child">
                          <object class="GtkScrolledWindow">
                            <property name="hscrollbar-policy">never</property>
                            <style>
                              <class name="om-scroll"/>
                            </style>
                            <property name="child">
                              <object class="GtkGridView" id="months_grid">
                                <property name="min-columns">2</property>
                                <property name="max-columns">8</property>
                                <property name="margin-top">24</property>
                                <property name="margin-bottom">1</property>
                                <property name="margin-start">32</property>
                                <property name="margin-end">32</property>
                                <property name="single-click-activate">true</property>
                                <style>
                                  <class name="card-grid"/>
                                </style>
                              </object>
                            </property>
                          </object>
                        </property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkStackPage">
                        <property name="name">years</property>
                        <property name="child">
                          <object class="GtkScrolledWindow">
                            <property name="hscrollbar-policy">never</property>
                            <style>
                              <class name="om-scroll"/>
                            </style>
                            <property name="child">
                              <object class="GtkGridView" id="years_grid">
                                <property name="min-columns">2</property>
                                <property name="max-columns">8</property>
                                <property name="margin-top">24</property>
                                <property name="margin-bottom">1</property>
                                <property name="margin-start">32</property>
                                <property name="margin-end">32</property>
                                <property name="single-click-activate">true</property>
                                <style>
                                  <class name="card-grid"/>
                                </style>
                              </object>
                            </property>
                          </object>
                        </property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkStackPage">
                        <property name="name">albums</property>
                        <property name="child">
                          <object class="GtkScrolledWindow">
                            <property name="hscrollbar-policy">never</property>
                            <style>
                              <class name="om-scroll"/>
                            </style>
                            <property name="child">
                              <object class="GtkGridView" id="album_grid">
                                <property name="min-columns">2</property>
                                <property name="max-columns">8</property>
                                <property name="margin-top">24</property>
                                <property name="margin-bottom">1</property>
                                <property name="margin-start">32</property>
                                <property name="margin-end">32</property>
                                <property name="single-click-activate">true</property>
                                <style>
                                  <class name="card-grid"/>
                                </style>
                              </object>
                            </property>
                          </object>
                        </property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkStackPage">
                        <property name="name">favourites</property>
                        <property name="child">
                          <object class="GtkScrolledWindow">
                            <property name="hscrollbar-policy">never</property>
                            <style>
                              <class name="om-scroll"/>
                            </style>
                            <property name="child">
                              <object class="GtkGridView" id="fav_grid">
                                <property name="min-columns">2</property>
                                <property name="max-columns">12</property>
                                <property name="margin-top">24</property>
                                <property name="margin-bottom">1</property>
                                <property name="margin-start">32</property>
                                <property name="margin-end">32</property>
                                <style>
                                  <class name="card-grid"/>
                                </style>
                              </object>
                            </property>
                          </object>
                        </property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkStackPage">
                        <property name="name">maps</property>
                        <property name="child">
                          <object class="AdwStatusPage">
                            <property name="icon-name">map-symbolic</property>
                            <property name="title" translatable="yes">Maps</property>
                            <property name="description" translatable="yes">Photos placed on a map by their location. Coming soon — this reads GPS from each photo's metadata.</property>
                          </object>
                        </property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkStackPage">
                        <property name="name">people</property>
                        <property name="child">
                          <object class="AdwStatusPage">
                            <property name="icon-name">system-users-symbolic</property>
                            <property name="title" translatable="yes">People</property>
                            <property name="description" translatable="yes">Photos grouped by the people in them. Coming soon — this needs on-device face detection.</property>
                          </object>
                        </property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkStackPage">
                        <property name="name">detail</property>
                        <property name="child">
                          <object class="GtkScrolledWindow">
                            <property name="hscrollbar-policy">never</property>
                            <style>
                              <class name="om-scroll"/>
                            </style>
                            <property name="child">
                              <object class="GtkBox" id="detail_box">
                                <property name="orientation">vertical</property>

                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">24</property>
                                    <property name="margin-top">24</property>
                                    <property name="margin-bottom">8</property>
                                    <property name="margin-start">32</property>
                                    <property name="margin-end">32</property>
                                    <child>
                                      <object class="GtkBox" id="detail_hero_slot"/>
                                    </child>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="orientation">vertical</property>
                                        <property name="spacing">6</property>
                                        <property name="valign">center</property>
                                        <child>
                                          <object class="GtkLabel" id="detail_name_label">
                                            <property name="xalign">0</property>
                                            <style>
                                              <class name="artist-heading"/>
                                            </style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel" id="detail_stats_label">
                                            <property name="xalign">0</property>
                                            <style>
                                              <class name="mono-dim"/>
                                            </style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>

                                <child>
                                  <object class="GtkGridView" id="detail_photos_grid">
                                    <property name="min-columns">2</property>
                                    <property name="max-columns">12</property>
                                    <property name="margin-top">20</property>
                                    <property name="margin-bottom">1</property>
                                    <property name="margin-start">32</property>
                                    <property name="margin-end">32</property>
                                    <property name="valign">start</property>
                                    <style>
                                      <class name="card-grid"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </property>
                          </object>
                        </property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

            <!-- Info panel: slides in from the right on single click. The
                 selected photo sits at the top (aligned with the paper), the
                 quick actions sit below it, then the file's details. -->
            <child>
              <object class="GtkRevealer" id="info_revealer">
                <property name="hexpand">false</property>
                <property name="transition-type">slide-left</property>
                <property name="transition-duration">300</property>
                <property name="valign">fill</property>
                <property name="child">
                  <object class="GtkBox" id="info_panel">
                    <property name="orientation">vertical</property>
                    <property name="spacing">14</property>
                    <property name="vexpand">true</property>
                    <style>
                      <class name="info-panel"/>
                    </style>

                    <child>
                      <object class="GtkOverlay" id="info_preview_slot">
                        <child type="overlay">
                          <object class="GtkButton" id="info_close_btn">
                            <property name="icon-name">window-close-symbolic</property>
                            <property name="tooltip-text" translatable="yes">Close</property>
                            <property name="halign">end</property>
                            <property name="valign">start</property>
                            <property name="margin-top">8</property>
                            <property name="margin-end">8</property>
                            <style>
                              <class name="flat"/>
                              <class name="info-close"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="GtkBox">
                        <property name="orientation">horizontal</property>
                        <property name="halign">center</property>
                        <property name="spacing">14</property>
                        <property name="margin-top">2</property>
                        <property name="margin-bottom">2</property>
                        <child>
                          <object class="GtkButton" id="info_rotate_left_btn">
                            <property name="icon-name">object-rotate-left-symbolic</property>
                            <property name="tooltip-text" translatable="yes">Rotate left</property>
                            <property name="valign">center</property>
                            <style>
                              <class name="flat"/>
                              <class name="info-action"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="info_rotate_right_btn">
                            <property name="icon-name">object-rotate-right-symbolic</property>
                            <property name="tooltip-text" translatable="yes">Rotate right</property>
                            <property name="valign">center</property>
                            <style>
                              <class name="flat"/>
                              <class name="info-action"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="info_fullscreen_btn">
                            <property name="icon-name">view-fullscreen-symbolic</property>
                            <property name="tooltip-text" translatable="yes">View full screen</property>
                            <property name="valign">center</property>
                            <style>
                              <class name="flat"/>
                              <class name="info-fs-btn"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="info_add_btn">
                            <property name="icon-name">list-add-symbolic</property>
                            <property name="tooltip-text" translatable="yes">Add to favourites or an album</property>
                            <property name="valign">center</property>
                            <style>
                              <class name="flat"/>
                              <class name="info-action"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="info_edit_btn">
                            <property name="icon-name">document-edit-symbolic</property>
                            <property name="tooltip-text" translatable="yes">Edit</property>
                            <property name="valign">center</property>
                            <style>
                              <class name="flat"/>
                              <class name="info-action"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="GtkLabel" id="info_title">
                        <property name="xalign">0</property>
                        <property name="ellipsize">end</property>
                        <property name="wrap">true</property>
                        <property name="lines">2</property>
                        <property name="max-width-chars">28</property>
                        <property name="width-chars">0</property>
                        <style>
                          <class name="info-title"/>
                        </style>
                      </object>
                    </child>

                    <child>
                      <object class="GtkScrolledWindow">
                        <property name="vexpand">true</property>
                        <property name="hscrollbar-policy">never</property>
                        <style>
                          <class name="om-scroll"/>
                        </style>
                        <property name="child">
                          <object class="GtkBox" id="info_rows_box">
                            <property name="orientation">vertical</property>
                            <property name="spacing">14</property>
                          </object>
                        </property>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>
      </object>
        </property>
        <!-- Lightbox: a full-window overlay revealed when a photo is opened -->
        <child type="overlay">
          <object class="GtkRevealer" id="lightbox_revealer">
            <property name="visible">false</property>
            <property name="transition-type">crossfade</property>
            <property name="transition-duration">150</property>
            <property name="halign">fill</property>
            <property name="valign">fill</property>
            <property name="child">
              <object class="GtkBox" id="lightbox">
                <property name="orientation">vertical</property>
                <style>
                  <class name="lightbox"/>
                </style>

                <child>
                  <object class="GtkCenterBox">
                    <property name="margin-top">12</property>
                    <property name="margin-start">16</property>
                    <property name="margin-end">16</property>
                    <property name="end-widget">
                      <object class="GtkBox">
                        <property name="spacing">4</property>
                        <child>
                          <object class="GtkButton" id="lightbox_fav_btn">
                            <property name="icon-name">easel-heart-symbolic</property>
                            <property name="tooltip-text" translatable="yes">Favourite</property>
                            <property name="valign">center</property>
                            <style>
                              <class name="flat"/>
                              <class name="lightbox-btn"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="lightbox_close_btn">
                            <property name="icon-name">window-close-symbolic</property>
                            <property name="tooltip-text" translatable="yes">Close</property>
                            <property name="valign">center</property>
                            <style>
                              <class name="flat"/>
                              <class name="lightbox-btn"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="vexpand">true</property>
                    <property name="spacing">8</property>
                    <property name="margin-start">12</property>
                    <property name="margin-end">12</property>
                    <child>
                      <object class="GtkButton" id="lightbox_prev_btn">
                        <property name="icon-name">go-previous-symbolic</property>
                        <property name="tooltip-text" translatable="yes">Previous</property>
                        <property name="valign">center</property>
                        <style>
                          <class name="flat"/>
                          <class name="lightbox-nav"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkPicture" id="lightbox_picture">
                        <property name="hexpand">true</property>
                        <property name="vexpand">true</property>
                        <property name="content-fit">contain</property>
                        <property name="can-shrink">true</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkVideo" id="lightbox_video">
                        <property name="visible">false</property>
                        <property name="hexpand">true</property>
                        <property name="vexpand">true</property>
                        <property name="autoplay">true</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="lightbox_next_btn">
                        <property name="icon-name">go-next-symbolic</property>
                        <property name="tooltip-text" translatable="yes">Next</property>
                        <property name="valign">center</property>
                        <style>
                          <class name="flat"/>
                          <class name="lightbox-nav"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>

                <child>
                  <object class="GtkLabel" id="lightbox_caption">
                    <property name="margin-top">8</property>
                    <property name="margin-bottom">16</property>
                    <property name="halign">center</property>
                    <property name="ellipsize">end</property>
                    <style>
                      <class name="lightbox-caption"/>
                    </style>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>

        <!-- Photo editor: a full-window overlay, photo left/centre, tools right -->
        <child type="overlay">
          <object class="GtkRevealer" id="edit_revealer">
            <property name="visible">false</property>
            <property name="transition-type">crossfade</property>
            <property name="transition-duration">150</property>
            <property name="halign">fill</property>
            <property name="valign">fill</property>
            <property name="child">
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <style>
                  <class name="editor"/>
                </style>

                <child>
                  <object class="GtkCenterBox">
                    <property name="margin-top">12</property>
                    <property name="margin-start">20</property>
                    <property name="margin-end">20</property>
                    <property name="margin-bottom">4</property>
                    <property name="start-widget">
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Edit Photo</property>
                        <style>
                          <class name="editor-title"/>
                        </style>
                      </object>
                    </property>
                    <property name="end-widget">
                      <object class="GtkBox">
                        <property name="spacing">8</property>
                        <child>
                          <object class="GtkButton" id="edit_cancel_btn">
                            <property name="label" translatable="yes">Cancel</property>
                            <style>
                              <class name="editor-cancel"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="edit_save_btn">
                            <property name="label" translatable="yes">Save a Copy</property>
                            <style>
                              <class name="suggested-action"/>
                              <class name="editor-save"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="vexpand">true</property>
                    <child>
                      <object class="GtkBox" id="edit_image_slot">
                        <property name="hexpand">true</property>
                        <property name="vexpand">true</property>
                        <property name="margin-start">20</property>
                        <property name="margin-end">16</property>
                        <property name="margin-top">8</property>
                        <property name="margin-bottom">20</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="edit_tools">
                        <property name="orientation">vertical</property>
                        <property name="spacing">12</property>
                        <property name="width-request">280</property>
                        <property name="margin-end">20</property>
                        <property name="margin-top">8</property>
                        <property name="margin-bottom">20</property>
                        <style>
                          <class name="edit-tools"/>
                        </style>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Adjust</property>
                            <property name="xalign">0</property>
                            <style>
                              <class name="editor-eyebrow"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Brightness</property>
                            <property name="xalign">0</property>
                            <style>
                              <class name="editor-slider-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkScale" id="edit_brightness">
                            <property name="draw-value">false</property>
                            <property name="adjustment">
                              <object class="GtkAdjustment">
                                <property name="lower">-100</property>
                                <property name="upper">100</property>
                                <property name="value">0</property>
                                <property name="step-increment">1</property>
                              </object>
                            </property>
                            <style>
                              <class name="editor-scale"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Contrast</property>
                            <property name="xalign">0</property>
                            <style>
                              <class name="editor-slider-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkScale" id="edit_contrast">
                            <property name="draw-value">false</property>
                            <property name="adjustment">
                              <object class="GtkAdjustment">
                                <property name="lower">-100</property>
                                <property name="upper">100</property>
                                <property name="value">0</property>
                                <property name="step-increment">1</property>
                              </object>
                            </property>
                            <style>
                              <class name="editor-scale"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Saturation</property>
                            <property name="xalign">0</property>
                            <style>
                              <class name="editor-slider-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkScale" id="edit_saturation">
                            <property name="draw-value">false</property>
                            <property name="adjustment">
                              <object class="GtkAdjustment">
                                <property name="lower">-100</property>
                                <property name="upper">100</property>
                                <property name="value">0</property>
                                <property name="step-increment">1</property>
                              </object>
                            </property>
                            <style>
                              <class name="editor-scale"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkSeparator">
                            <property name="margin-top">6</property>
                            <property name="margin-bottom">6</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkBox">
                            <property name="spacing">8</property>
                            <property name="homogeneous">true</property>
                            <child>
                              <object class="GtkButton" id="edit_rotate_left_btn">
                                <property name="tooltip-text" translatable="yes">Rotate left</property>
                                <child>
                                  <object class="AdwButtonContent">
                                    <property name="icon-name">object-rotate-left-symbolic</property>
                                    <property name="label" translatable="yes">Left</property>
                                  </object>
                                </child>
                                <style>
                                  <class name="editor-tool-btn"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="edit_rotate_right_btn">
                                <property name="tooltip-text" translatable="yes">Rotate right</property>
                                <child>
                                  <object class="AdwButtonContent">
                                    <property name="icon-name">object-rotate-right-symbolic</property>
                                    <property name="label" translatable="yes">Right</property>
                                  </object>
                                </child>
                                <style>
                                  <class name="editor-tool-btn"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="edit_reset_btn">
                            <property name="label" translatable="yes">Reset</property>
                            <property name="margin-top">4</property>
                            <style>
                              <class name="editor-tool-btn"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>
      </object>
        </property>
      </object>
    </property>
  </template>
</interface>
