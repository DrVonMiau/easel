{
    "id": "io.github.drvonmiau.Easel",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "easel",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=xdg-pictures",
        "--filesystem=host-os:ro",
        "--filesystem=xdg-run/gvfs",
        "--filesystem=xdg-run/gvfsd"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "ibm-plex-fonts",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/share/fonts",
                "install -m644 plex-mono/fonts/complete/ttf/IBMPlexMono-Regular.ttf plex-mono/fonts/complete/ttf/IBMPlexMono-Medium.ttf plex-mono/fonts/complete/ttf/IBMPlexMono-SemiBold.ttf plex-mono/fonts/complete/ttf/IBMPlexMono-Bold.ttf /app/share/fonts/",
                "install -m644 plex-sans/fonts/complete/ttf/IBMPlexSans-Regular.ttf plex-sans/fonts/complete/ttf/IBMPlexSans-Medium.ttf plex-sans/fonts/complete/ttf/IBMPlexSans-SemiBold.ttf plex-sans/fonts/complete/ttf/IBMPlexSans-Bold.ttf /app/share/fonts/"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/IBM/plex/releases/download/%40ibm%2Fplex-mono%401.1.0/ibm-plex-mono.zip",
                    "sha256": "4bfc936d0e1fd19db6327a3786eabdbc3dc0d464500576f6458f6706df68d26c",
                    "dest": "plex-mono"
                },
                {
                    "type": "archive",
                    "url": "https://github.com/IBM/plex/releases/download/%40ibm%2Fplex-sans%401.1.0/ibm-plex-sans.zip",
                    "sha256": "fb365d910566e6d199cc2c15579a7dd9a267128e18431a394ed81f1970c69200",
                    "dest": "plex-sans"
                }
            ]
        },
        {
            "name": "easel",
            "builddir": true,
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "dir",
                    "path": ".",
                    "skip": [
                        ".git",
                        ".flatpak-builder",
                        "_flatpak"
                    ]
                }
            ]
        }
    ]
}
